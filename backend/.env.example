DATABASE_URL=postgresql+psycopg://mergen:mergen@postgres:5432/mergenvision
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=face_samples_arcface_r50_webface_v1
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_FACES=mergenvision-faces
MODEL_VERSION=arcface_r50_webface4m_v1
PREPROCESS_VERSION=five-point-umeyama-112x112
DETECTOR_VERSION=yolov8n-face-v1
ALIGNMENT_VERSION=umeyama-5point-112x112
RECOGNITION_THRESHOLD=0.55
ANONYMOUS_THRESHOLD=0.40
MIN_CONFIDENCE=0.25
MAX_UPLOAD_BYTES=10485760
GPU_WORKER_SOCKETS=/run/mvision/worker-0.sock,/run/mvision/worker-1.sock,/run/mvision/worker-2.sock
GPU_WORKER_TIMEOUT_SECONDS=120
GPU_WORKER_BATCH_SIZE=128
