OTEL_EXPORT_TIMEOUT_SECONDS=2
OTEL_BSP_MAX_QUEUE_SIZE=2048
OTEL_BSP_MAX_EXPORT_BATCH_SIZE=256
OTEL_BSP_SCHEDULE_DELAY_MILLIS=500
OTEL_SHUTDOWN_TIMEOUT_SECONDS=3
