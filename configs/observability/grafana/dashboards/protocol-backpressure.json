{
  "uid": "mvision-protocol-backpressure",
  "title": "Protocol Backpressure",
  "schemaVersion": 41,
  "version": 1,
  "refresh": "15s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Queue Depth",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "max by (queue_type) (mvision_live_protocol_queue_depth)"}],
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Dropped Messages",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "sum by (type) (rate(mvision_live_protocol_dropped_total[5m]))"}],
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8}
    }
  ]
}
